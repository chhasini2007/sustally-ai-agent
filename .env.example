# LLM Configuration
LLM_PROVIDER=ollama

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
# Timeouts: connection (fail fast if offline), read (allow extra time for model cold loading)
OLLAMA_CONNECT_TIMEOUT=3
OLLAMA_READ_TIMEOUT=20

# currently inactive — set LLM_PROVIDER=omniroute to enable
# OMNIROUTE_BASE_URL=http://localhost:20128/v1
# OMNIROUTE_MODEL=auto
# OMNIROUTE_CONNECT_TIMEOUT=3
# OMNIROUTE_READ_TIMEOUT=12

# Grok configuration — set LLM_PROVIDER=grok to enable (required for Streamlit Community Cloud)
# GROK_API_KEY=your-grok-api-key-here
# GROK_MODEL=grok-4.1-fast
# GROK_CONNECT_TIMEOUT=3
# GROK_READ_TIMEOUT=20

# Demo Access Configuration (for run_demo.ps1)
DEMO_USER=admin
DEMO_PASS=change-this-password-for-demo
