# Streamlit Cloud Secrets Configuration
# Rename this file to secrets.toml when testing locally with Streamlit secrets,
# or paste these key-value pairs into the Secrets section of your Streamlit Community Cloud app settings.

LLM_PROVIDER = "grok"
GROK_API_KEY = "your-grok-api-key-here"
GROK_MODEL = "grok-4.1-fast"
GROK_CONNECT_TIMEOUT = 3
GROK_READ_TIMEOUT = 20
