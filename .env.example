# LLM Configuration
LLM_PROVIDER=ollama

# Ollama Configuration (Local Development)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_CONNECT_TIMEOUT=3
OLLAMA_READ_TIMEOUT=20

# OpenAI Configuration (Cloud Deployment or Alternative Local Provider)
# OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_CONNECT_TIMEOUT=3
OPENAI_READ_TIMEOUT=20

# Hugging Face Configuration (Optional - for sentence-transformers hub authentication if needed)
# HF_TOKEN=your-huggingface-token-here

# Demo Access Configuration (for run_demo.ps1)
DEMO_USER=admin
DEMO_PASS=change-this-password-for-demo

# Streamlit App Authentication Gate Configuration
STREAMLIT_APP_USER=admin
STREAMLIT_APP_PASSWORD=your-secret-password-here
