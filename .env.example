# LLM Configuration
LLM_PROVIDER=ollama

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
# Timeouts: connection (fail fast if offline), read (allow extra time for model cold loading)
OLLAMA_CONNECT_TIMEOUT=3
OLLAMA_READ_TIMEOUT=20

# OpenAI configuration — set LLM_PROVIDER=openai to enable (required for Streamlit Community Cloud)
# OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_CONNECT_TIMEOUT=3
OPENAI_READ_TIMEOUT=20

# Demo Access Configuration (for run_demo.ps1)
DEMO_USER=admin
DEMO_PASS=change-this-password-for-demo

# Streamlit App Authentication Gate Configuration
STREAMLIT_APP_USER=admin
STREAMLIT_APP_PASSWORD=your-secret-password-here
