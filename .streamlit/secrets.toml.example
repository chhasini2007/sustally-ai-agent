# Streamlit Cloud Secrets Configuration
# Rename this file to secrets.toml when testing locally with Streamlit secrets,
# or paste these key-value pairs into the Secrets section of your Streamlit Community Cloud app settings.

# LLM Config (Use openai for Streamlit Community Cloud)
LLM_PROVIDER = "openai"
OPENAI_API_KEY = "your-openai-api-key-here"
OPENAI_MODEL = "gpt-4o-mini"
OPENAI_CONNECT_TIMEOUT = 3
OPENAI_READ_TIMEOUT = 20

# Streamlit App Authentication Gate
STREAMLIT_APP_USER = "admin"
STREAMLIT_APP_PASSWORD = "your-secret-password-here"
